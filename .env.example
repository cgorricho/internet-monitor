# Internet Connection Monitor - Environment Configuration Template
# Copy this file to .env and modify values as needed

# Database Configuration
DATABASE_PATH=data/internet_monitor.db
BACKUP_DATABASE_PATH=data/backups/

# Logging Configuration  
LOG_PATH=logs/
LOG_LEVEL=INFO
LOG_ROTATION=10MB

# Peak Hours Configuration (24-hour format)
PEAK_HOURS_START=09:00
PEAK_HOURS_END=18:00

# Monitoring Intervals (in minutes)
# Peak hours
PEAK_QUICK_INTERVAL=2
PEAK_SPEEDTEST_INTERVAL=10
PEAK_ANALYSIS_INTERVAL=30

# Off-peak hours  
OFFPEAK_QUICK_INTERVAL=5
OFFPEAK_SPEEDTEST_INTERVAL=20
OFFPEAK_ANALYSIS_INTERVAL=60

# Alert Thresholds
# Download Speed (Mbps)
ALERT_DOWNLOAD_WARNING=25
ALERT_DOWNLOAD_CRITICAL=10

# Upload Speed (Mbps)
ALERT_UPLOAD_WARNING=5
ALERT_UPLOAD_CRITICAL=1

# Ping Latency (milliseconds)
ALERT_PING_WARNING=50
ALERT_PING_CRITICAL=100

# Packet Loss (percentage)
ALERT_PACKET_LOSS_WARNING=1
ALERT_PACKET_LOSS_CRITICAL=3

# WiFi Signal Strength (dBm, negative values)
ALERT_WIFI_WARNING=-70
ALERT_WIFI_CRITICAL=-80

# DNS Resolution (milliseconds)
ALERT_DNS_WARNING=100
ALERT_DNS_CRITICAL=500

# Data Retention
DATA_RETENTION_DAYS=90

# Dashboard Configuration
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8050
DASHBOARD_DEBUG=False
DASHBOARD_AUTO_RELOAD=True
DASHBOARD_UPDATE_INTERVAL=60

# Network Test Configuration
SPEEDTEST_TIMEOUT=60
PING_COUNT=4
DNS_TEST_DOMAIN=google.com
PING_HOST=8.8.8.8

# Application Settings
APP_TIMEZONE=America/New_York
MAX_RETRIES=3
RETRY_DELAY=5